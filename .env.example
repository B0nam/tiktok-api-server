# TikTok API Server Configuration
# Copy this to .env and fill in your values

# Required: Comma-separated ms_tokens (get from browser cookies after visiting tiktok.com)
# MS_TOKENS=token1,token2,token3

# Optional: Proxy configuration (e.g., http://user:pass@proxy:port)
# PROXY=

# Optional: Run browser in headless mode (default: true)
# HEADLESS=true

# Optional: Number of concurrent sessions (default: 3)
# NUM_SESSIONS=3